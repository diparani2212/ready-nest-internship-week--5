{
  "framework": "nextjs",
  "buildCommand": "cd frontend && npm install --production=false && npm run build && (cp -R .vercel/output ../.vercel/output || cp -R .next ../.next || true)",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
